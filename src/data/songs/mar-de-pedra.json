    {
      "id": "v1",
      "type": "verse",
      "tag": "V1",
      "name": "Verso 1",
      "lines": [
        {
          "parts": [
            { "chord": "Am", "text": "Pedras no peito, " },
            { "chord": "F", "text": "areia no olhar" }
          ]
        },
        {
          "parts": [
            { "chord": "C", "text": "O mar de pedra " },
            { "chord": "G", "text": "quer me ensinar" }
          ]
        },
        {
          "parts": [
            { "chord": "Am", "text": "Que a força mora " },
            { "chord": "F", "text": "no que não quebra" }
          ]
        },
        {
          "parts": [
            { "chord": "C", "text": "E a calma chega " },
            { "chord": "G", "text": "quando a gente espera" }
          ]
        }
      ]
    },
    {
      "id": "pr1",
      "type": "prechorus",
      "tag": "Pr",
      "name": "Pré-Refrão",
      "lines": [
        {
          "parts": [
            { "chord": "Dm", "text": "Segura o tempo, " },
            { "chord": "Am", "text": "respira fundo" }
          ]
        },
        {
          "parts": [
            { "chord": "F", "text": "O que era peso " },
            { "chord": "E7", "text": "vira segundo" }
          ]
        }
      ]
    },
    {
      "id": "r1",
      "type": "chorus",
      "tag": "R",
      "name": "Refrão",
      "annotation": "Abre as cordas",
      "lines": [
        {
          "parts": [
            { "chord": "Am", "text": "Mar de pedra, " },
            { "chord": "F", "text": "não me afoga" }
          ]
        },
        {
          "parts": [
            { "chord": "C", "text": "Me ensina a " },
            { "chord": "G", "text": "ficar de pé" }
          ]
        },
        {
          "parts": [
            { "chord": "Am", "text": "Se a onda quebra, " },
            { "chord": "F", "text": "eu me recompôs" }
          ]
        },
        {
          "parts": [
            { "chord": "C", "text": "E sigo o rumo " },
            { "chord": "E7", "text": "que o peito quer" }
          ]
        }
      ]
    },
    {
      "id": "v2",
      "type": "verse",
      "tag": "V2",
      "name": "Verso 2",
      "lines": [
        {
          "parts": [
            { "chord": "Am", "text": "Salgado o vento, " },
            { "chord": "F", "text": "quente o chão" }
          ]
        },
        {
          "parts": [
            { "chord": "C", "text": "Cada ferida " },
            { "chord": "G", "text": "vira lição" }
          ]
        },
        {
          "parts": [
            { "chord": "Am", "text": "Não peço calma " },
            { "chord": "F", "text": "sem ter luta" }
          ]
        },
        {
          "parts": [
            { "chord": "C", "text": "Só peço força " },
            { "chord": "G", "text": "pra me manter" }
          ]
        }
      ]
    },
    {
      "id": "f1",
      "type": "ending",
      "tag": "F",
      "name": "Final",
