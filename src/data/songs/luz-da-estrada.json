      "type": "verse",
      "tag": "V1",
      "name": "Verso 1",
      "lines": [
        {
          "parts": [
            { "chord": "G", "text": "Abri a janela " },
            { "chord": "D/F#", "text": "pro sol chegar" }
          ]
        },
        {
          "parts": [
            { "chord": "Em", "text": "O vento trouxe " },
            { "chord": "C", "text": "um novo cantar" }
          ]
        },
        {
          "parts": [
            { "chord": "G", "text": "Deixei a pressa " },
            { "chord": "D", "text": "no chão de casa" }
          ]
        },
        {
          "parts": [
            { "chord": "Em", "text": "E fui buscar " },
            { "chord": "C", "text": "a luz da estrada" }
          ]
        }
      ]
    },
    {
      "id": "r1",
      "type": "chorus",
      "tag": "R",
      "name": "Refrão",
      "annotation": "Bate com a mão no tampo",
      "lines": [
        {
          "parts": [
            { "chord": "C", "text": "Vem comigo, " },
            { "chord": "G", "text": "não tem pressa" }
          ]
        },
        {
          "parts": [
            { "chord": "D", "text": "Cada passo " },
            { "chord": "Em", "text": "é uma benção" }
          ]
        },
        {
          "parts": [
            { "chord": "C", "text": "O horizonte " },
            { "chord": "G", "text": "abre a mesa" }
          ]
        },
        {
          "parts": [
            { "chord": "D", "text": "E a gente " },
            { "chord": "G", "text": "sente a certeza" }
          ]
        }
      ]
    },
    {
      "id": "v2",
      "type": "verse",
      "tag": "V2",
      "name": "Verso 2",
      "lines": [
        {
          "parts": [
            { "chord": "G", "text": "Achei no bolso " },
            { "chord": "D/F#", "text": "uma carta velha" }
          ]
        },
        {
          "parts": [
            { "chord": "Em", "text": "Palavras simples " },
            { "chord": "C", "text": "de quem me espera" }
          ]
        },
        {
          "parts": [
            { "chord": "G", "text": "Se o caminho " },
            { "chord": "D", "text": "parece longe" }
          ]
        },
        {
          "parts": [
            { "chord": "Em", "text": "A canção " },
            { "chord": "C", "text": "encurta a ponte" }
          ]
        }
      ]
    },
    {
      "id": "b1",
      "type": "bridge",
      "tag": "B",
      "name": "Ponte",
      "annotation": "Sobe um pouco a dinâmica",
      "lines": [
        {
          "parts": [
            { "chord": "Am", "text": "Não preciso " },
            { "chord": "Em", "text": "saber o fim" }
          ]
        },
        {
          "parts": [
            { "chord": "C", "text": "Só seguir " },
            { "chord": "D", "text": "o que o peito diz" }
          ]
        }
      ]
    },
    {
      "id": "f1",
      "type": "ending",
