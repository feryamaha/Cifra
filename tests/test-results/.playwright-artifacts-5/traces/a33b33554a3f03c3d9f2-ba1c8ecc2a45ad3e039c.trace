{"type":"frame-snapshot","snapshot":{"callId":"call@8","snapshotName":"after@call@8","pageId":"page@c2fd67d31cbb0cea316ebfc94a62864d","frameId":"frame@ce5df4d4db200264dc075fb5e50f5565","frameUrl":"http://localhost:3000/privacidade","doctype":"html","html":["HTML",{"lang":"pt-BR","class":"chakra_petch_123b5930-module__lTOfDW__variable inter_29f246d4-module__8Y_Bfa__variable jetbrains_mono_655dea0a-module__YW9YkG__variable"},["HEAD",{},["BASE",{"href":"http://localhost:3000/privacidade"}],["META",{"charset":"utf-8"}],["META",{"name":"viewport","content":"width=device-width, initial-scale=1"}],["LINK",{"rel":"stylesheet","href":"/_next/static/chunks/%5Broot-of-the-server%5D__0k7f9wf._.css","data-precedence":"next_static/chunks/[root-of-the-server]__0k7f9wf._.css"}],["META",{"name":"theme-color","content":"#f2ab3c"}],["TITLE",{},"Política de Privacidade · Cifra Tom"],["META",{"name":"description","content":"Cifras 100% focadas em violão: transposição, capotraste calculado, números da escala e shapes por afinação."}],["LINK",{"rel":"manifest","href":"/manifest.json"}],["LINK",{"rel":"icon","href":"/favicon.ico","sizes":"any"}],["LINK",{"rel":"icon","href":"/favico.png","type":"image/png","sizes":"488x511"}],["LINK",{"rel":"apple-touch-icon","href":"/favico.png","type":"image/png"}],["META",{"name":"next-size-adjust","content":""}],["STYLE",{},"@font-face{font-family:'__nextjs-Geist';font-style:normal;font-weight:400 600;font-display:swap;src:url(/__nextjs_font/geist-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF}@font-face{font-family:'__nextjs-Geist Mono';font-style:normal;font-weight:400 600;font-display:swap;src:url(/__nextjs_font/geist-mono-latin-ext.woff2) format('woff2');unicode-range:U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U